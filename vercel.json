{
  "buildCommand": "pnpm --filter @workspace/ahmed-portfolio run build",
  "outputDirectory": "artifacts/ahmed-portfolio/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/",
    "NETLIFY": "true"
  }
}
